<scene version="3.0.0">
    <path value="../../../common"/>

    <default name="integrator" value="path"/>
    <integrator type="moment">
        <integrator type="$integrator">
            <integer name="max_depth" value="3"/>
        </integrator>
    </integrator>

    <sensor type="perspective">
        <float name="fov" value="45.0"/>
        <float name="shutter_close" value="1.0"/>
        <transform name="to_world">
            <lookat origin="0, 4, -8"
                    target="0, 1, 0"
                    up    ="0, 1, 0"/>
        </transform>
        <film type="hdrfilm">
            <rfilter type="box"/>
            <integer name="width" value="48"/>
            <integer name="height" value="48"/>
        </film>
        <sampler type="independent">
            <integer name="sample_count" value="$spp"/>
        </sampler>
    </sensor>

    <emitter type="directional">
        <vector name="direction" value="0,-0.1,1"/>
        <rgb name="irradiance" value="5.0"/>
    </emitter>

    <shape type="shapegroup" id="sphere_group">
        <shape type="sphere">
            <float name="radius" value="0.8"/>
            <bsdf type="diffuse">
                <rgb name="reflectance" value="0.8 0.2 0.2"/>
            </bsdf>
        </shape>
    </shape>

    <shape type="shapegroup" id="cube_group">
        <shape type="cube">
            <bsdf type="diffuse">
                <rgb name="reflectance" value="0.2 0.8 0.2"/>
            </bsdf>
        </shape>
    </shape>

    <shape type="shapegroup" id="cylinder_group">
        <shape type="cylinder">
            <point name="p0" x="0" y="0" z="0"/>
            <point name="p1" x="0" y="1.5" z="0"/>
            <float name="radius" value="0.5"/>
            <bsdf type="diffuse">
                <rgb name="reflectance" value="0.2 0.2 0.8"/>
            </bsdf>
        </shape>
    </shape>

    <shape type="instance">
        <ref id="sphere_group"/>
        <animation name="to_world">
            <transform time="0.0">
                <translate x="-2" y="0.8" z="0.0"/>
            </transform>
            <transform time="1.0">
                <translate x="-2" y="2.5" z="0.0"/>
            </transform>
        </animation>
    </shape>


    <!-- We use a large number of rotation keys here to ensure OptiX & Embree results match.
    Embree uses SLERP to interpolate quaternions, and OptiX uses the cheaper NLERP. These
    do not match for large rotations.
    -->
    <shape type="instance">
        <ref id="cube_group"/>
        <animation name="to_world">
            <transform time="0.0">
                <scale x="0.7" y="1.2" z="0.7"/>
                <rotate x="0" y="1" z="0" angle="0.0"/>
                <translate x="0.0" y="0.7" z="0.0"/>
            </transform>
            <transform time="0.111111">
                <scale x="0.7" y="1.2" z="0.7"/>
                <rotate x="0" y="1" z="0" angle="10.0"/>
                <translate x="0.0" y="0.7" z="0.0"/>
            </transform>
            <transform time="0.222222">
                <scale x="0.7" y="1.2" z="0.7"/>
                <rotate x="0" y="1" z="0" angle="20.0"/>
                <translate x="0.0" y="0.7" z="0.0"/>
            </transform>
            <transform time="0.333333">
                <scale x="0.7" y="1.2" z="0.7"/>
                <rotate x="0" y="1" z="0" angle="30.0"/>
                <translate x="0.0" y="0.7" z="0.0"/>
            </transform>
            <transform time="0.444444">
                <scale x="0.7" y="1.2" z="0.7"/>
                <rotate x="0" y="1" z="0" angle="40.0"/>
                <translate x="0.0" y="0.7" z="0.0"/>
            </transform>
            <transform time="0.555556">
                <scale x="0.7" y="1.2" z="0.7"/>
                <rotate x="0" y="1" z="0" angle="50.0"/>
                <translate x="0.0" y="0.7" z="0.0"/>
            </transform>
            <transform time="0.666667">
                <scale x="0.7" y="1.2" z="0.7"/>
                <rotate x="0" y="1" z="0" angle="60.0"/>
                <translate x="0.0" y="0.7" z="0.0"/>
            </transform>
            <transform time="0.777778">
                <scale x="0.7" y="1.2" z="0.7"/>
                <rotate x="0" y="1" z="0" angle="70.0"/>
                <translate x="0.0" y="0.7" z="0.0"/>
            </transform>
            <transform time="0.888889">
                <scale x="0.7" y="1.2" z="0.7"/>
                <rotate x="0" y="1" z="0" angle="80.0"/>
                <translate x="0.0" y="0.7" z="0.0"/>
            </transform>
            <transform time="1.0">
                <scale x="0.7" y="1.2" z="0.7"/>
                <rotate x="0" y="1" z="0" angle="90.0"/>
                <translate x="0.0" y="0.7" z="0.0"/>
            </transform>
        </animation>
    </shape>

    <shape type="instance">
        <ref id="cylinder_group"/>
        <animation name="to_world">
            <transform time="0.0">
                <scale x="1.5" y="1.0" z="1.5"/>
                <translate x="2" y="-1" z="0.0"/>
            </transform>
            <transform time="1.0">
                <scale x="1.5" y="3.0" z="1.5"/>
                <translate x="2" y="-1" z="0.0"/>
            </transform>
        </animation>
    </shape>
</scene>
